<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:letterSpacing="0.32"
                android:text="POKÉDEX"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/appSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:alpha="0.85"
                android:text="Find any Pokémon"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_search_field">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/searchInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:autofillHints="username"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="52dp"
                    android:paddingEnd="64dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/searchButton"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/search_button"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="22dp"
                    app:icon="@drawable/ic_search"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="#FFFFFFFF" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_hero_card"
                android:elevation="6dp"
                android:padding="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/heroDecoration"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="-40dp"
                    android:layout_marginEnd="-40dp"
                    android:alpha="0.07"
                    android:contentDescription="@null"
                    android:rotation="-15"
                    android:src="@drawable/ic_pokeball" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/pokemonId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="#025" />

                    <TextView
                        android:id="@+id/pokemonName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_primary"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        tools:text="Pikachu" />

                    <FrameLayout
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:layout_marginTop="12dp">

                        <View
                            android:id="@+id/spriteHalo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_sprite_halo" />

                        <ImageView
                            android:id="@+id/pokemonSprite"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_gravity="center"
                            android:contentDescription="Pokemon sprite"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/typesContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_hero_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.18"
                    android:text="@string/base_stats"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <include
                    android:id="@+id/rowHp"
                    layout="@layout/item_stat_row" />

                <include
                    android:id="@+id/rowAttack"
                    layout="@layout/item_stat_row" />

                <include
                    android:id="@+id/rowDefense"
                    layout="@layout/item_stat_row" />

                <include
                    android:id="@+id/rowSpAtk"
                    layout="@layout/item_stat_row" />

                <include
                    android:id="@+id/rowSpDef"
                    layout="@layout/item_stat_row" />

                <include
                    android:id="@+id/rowSpeed"
                    layout="@layout/item_stat_row" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:alpha="0.85"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_pokeball" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/empty_title"
                    android:textColor="#FFFFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:alpha="0.85"
                    android:text="@string/empty_subtitle"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_hero_card"
                android:padding="16dp"
                android:textColor="@color/error"
                android:textSize="15sp"
                android:visibility="gone"
                tools:text="Pokemon not found"
                tools:visibility="visible" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFFFF"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
